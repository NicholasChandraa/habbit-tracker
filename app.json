{
  "expo": {
    "name": "Habit Tracker",
    "slug": "habit-tracker-rn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_ht.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.nicholaschandara.habittracker",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_ht.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "897540dd-7752-4af7-9e08-63566d54c1ae"
      }
    }
  }
}
